# YouTube Data API v3 key, used by the Latest Videos feature
# (see _specs/features/latest-videos/spec.md). Restrict it in Google
# Cloud Console to HTTP referrers on the production domain (and
# localhost for local development) — this key is bundled into public
# client-side code, so referrer restriction is the security boundary,
# not secrecy.
VITE_YOUTUBE_API_KEY=

# The DavesFunRC channel's "uploads" playlist ID (not the channel ID).
# Look this up once via:
#   GET https://www.googleapis.com/youtube/v3/channels
#     ?part=contentDetails&forHandle=DavesFunRC&key=<your key>
# and read .items[0].contentDetails.relatedPlaylists.uploads from the
# response. It doesn't change, so it only needs to be resolved once.
VITE_YOUTUBE_UPLOADS_PLAYLIST_ID=
